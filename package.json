{
  "name": "openmemory",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "automation": "bash ./scripts/automation.sh",
    "automation:prepush": "bash ./scripts/automation.sh prepush",
    "automation:prepush:containers": "bash ./scripts/automation.sh prepush:containers",
    "automation:e2e:containers": "bash ./scripts/automation.sh e2e:containers",
    "automation:e2e:containers:smoke": "bash ./scripts/automation.sh e2e:containers --smoke",
    "automation:verify": "bash ./scripts/automation.sh verify",
    "automation:check-resources": "bash ./scripts/automation.sh check-resources",
    "automation:suggest-system": "bash ./scripts/automation.sh suggest-system",
    "automation:install-hooks": "bash ./scripts/automation.sh install-hooks",
    "prepush": "bash ./scripts/pre-push-checks.sh",
    "prepush:fast": "PREPUSH_FAST=1 bash ./scripts/pre-push-checks.sh",
    "prepush:parallel": "PARALLEL_TESTS=1 bash ./scripts/pre-push-checks.sh",
    "prepush:containers": "RUN_CONTAINER_E2E=1 SKIP_HEAVY=1 bash ./scripts/pre-push-checks.sh",
    "e2e:containers": "bash ./scripts/e2e-containers.sh",
    "e2e:containers:smoke": "CRITICAL_ONLY=1 bash ./scripts/e2e-containers.sh",
    "install": "cd backend && bun install",
    "clean:artifacts": "bun ./scripts/cleanup-artifacts.mjs",
    "build": "cd backend && bun run build",
    "start": "cd backend && bun run start",
    "dev": "cd backend && bun run dev",
    "test": "cd backend && bun run test",
    "lint": "cd dashboard && bun run lint",
    "check:logger-spy": "bash ./scripts/check-logger-spy.sh",
    "check:logger-spy-repo": "bash ./scripts/check-logger-spy-repo.sh",
    "install-hooks": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit && chmod +x .githooks/pre-push",
    "test:pg": "./scripts/run_pg_tests.sh"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.934.0",
    "@types/bun": "1.3.2",
    "@types/node": "^22",
    "@ai-sdk/react": "^2.0.98",
      "ai": "^5.0.98",
    "playwright": "^1.56.1"
  }
}
